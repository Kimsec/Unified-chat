# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
# Public HTTPS URL used for YouTube/Kick OAuth + Kick webhooks
APP_BASE_URL=https://your-public-domain
LOG_LEVEL=info
LOGIN_PASSWORD_HASH=
SESSION_SECRET_KEY=
# Keep true for the public HTTPS domain
SESSION_COOKIE_SECURE=true
# HTTPS origins allowed to embed /popout, space- or comma-separated
POPUP_ALLOWED_FRAME_ANCESTORS=https://stream.kimsec.net

# ── Database ────────────────────────────────────────────
DATABASE_PATH=data/unified_chat.db

# ── Twitch ──────────────────────────────────────────────
# Get from https://dev.twitch.tv/console/apps > Your App > Client ID
TWITCH_CLIENT_ID=
# Your numeric Twitch user ID (use https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/)
TWITCH_BROADCASTER_ID=
# Path to twitch_tokens.json managed by stream-control (read-only)
TWITCH_TOKENS_PATH=/path/to/stream-control/twitch_tokens.json
TWITCH_EVENTSUB_WS_URL=wss://eventsub.wss.twitch.tv/ws

# ── YouTube ─────────────────────────────────────────────
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# See README.md for step-by-step setup instructions
YOUTUBE_CLIENT_SECRETS_FILE=google-client-secret.json
YOUTUBE_TOKEN_PATH=data/youtube_tokens.json
# Optional override only if you need a non-standard callback URL.
# Otherwise Unified Chat uses {APP_BASE_URL}/auth/youtube/callback automatically.
# YOUTUBE_REDIRECT_URI=https://your-public-domain/auth/youtube/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly
YOUTUBE_POLL_FALLBACK_SEC=8

# ── Kick ────────────────────────────────────────────────
# Get from https://kick.com/settings/developer > Your App
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Set this to enable app-token mode (no manual auth needed, fully automatic)
# Find your numeric user ID: see README.md for instructions
KICK_BROADCASTER_USER_ID=
KICK_TOKEN_PATH=data/kick_tokens.json
# Optional override only if you need a non-standard callback URL.
# Otherwise Unified Chat uses {APP_BASE_URL}/auth/kick/callback automatically.
# KICK_REDIRECT_URI=https://your-public-domain/auth/kick/callback
KICK_SCOPE=events:subscribe
