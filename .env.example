# ── Server ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8090
# Public HTTPS URL used for YouTube/Kick OAuth + Kick webhooks
APP_BASE_URL=https://your-public-domain
LOG_LEVEL=info
LOGIN_PASSWORD_HASH=
SESSION_SECRET_KEY=
# Keep true for the public HTTPS domain
SESSION_COOKIE_SECURE=true
# HTTPS origins allowed to embed /popout, space- or comma-separated (empty = same-origin only).
# e.g. your stream-control domain: https://stream.your-domain.com
POPUP_ALLOWED_FRAME_ANCESTORS=
# Optional shared secret: /popout?token=<this> logs the embed into a full session
# (chat feed + replying) without a manual login. Empty = off. Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POPOUT_TOKEN=

# ── Database ────────────────────────────────────────────
DATABASE_PATH=data/unified_chat.db

# ── Twitch ──────────────────────────────────────────────
# Get from https://dev.twitch.tv/console/apps > Your App > Client ID
TWITCH_CLIENT_ID=
# Your numeric Twitch user ID (use https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/)
TWITCH_BROADCASTER_ID=
TWITCH_EVENTSUB_WS_URL=wss://eventsub.wss.twitch.tv/ws
#
# What decides the mode is TWITCH_CLIENT_SECRET: empty = read-only (some other
# app mints the token), set = unified-chat mints/refreshes it itself.
# TWITCH_TOKENS_PATH just says WHERE the token file is.
#
# 1) STANDALONE (default, no stream-control): set TWITCH_CLIENT_SECRET, leave
#    TWITCH_TOKENS_PATH empty (defaults to data/twitch_tokens.json). A "Connect
#    Twitch" button appears; authorize once and it refreshes the token forever.
TWITCH_CLIENT_SECRET=
#
# 2) WITH stream-control (or any external minter): leave TWITCH_CLIENT_SECRET
#    empty and point TWITCH_TOKENS_PATH at that app's token file (ABSOLUTE path —
#    a relative ../ path resolves from the process working dir and is fragile).
#    unified-chat only READS it - no "Connect Twitch" button.
#      TWITCH_TOKENS_PATH=/absolute/path/to/stream-control/twitch_tokens.json
TWITCH_TOKENS_PATH=data/twitch_tokens.json
# OAuth callback (register this exact URL in the Twitch dev console). Default:
#   {APP_BASE_URL}/auth/twitch/callback
TWITCH_REDIRECT_URI=
TWITCH_SCOPES=user:read:chat user:write:chat channel:read:hype_train moderator:manage:banned_users moderator:manage:chat_messages channel:read:redemptions

# ── YouTube ─────────────────────────────────────────────
# Path to the OAuth client secrets JSON downloaded from Google Cloud Console
# See README.md for step-by-step setup instructions
YOUTUBE_CLIENT_SECRETS_FILE=google-client-secret.json
YOUTUBE_TOKEN_PATH=data/youtube_tokens.json
# Optional override only if you need a non-standard callback URL.
# Otherwise Unified Chat uses {APP_BASE_URL}/auth/youtube/callback automatically.
# YOUTUBE_REDIRECT_URI=https://your-public-domain/auth/youtube/callback
YOUTUBE_SCOPES=https://www.googleapis.com/auth/youtube.readonly

# ── Kick ────────────────────────────────────────────────
# Get from https://kick.com/settings/developer > Your App
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
# Set this to enable app-token mode (no manual auth needed, fully automatic)
# Find your numeric user ID: see README.md for instructions
KICK_BROADCASTER_USER_ID=
KICK_TOKEN_PATH=data/kick_tokens.json
# Optional override only if you need a non-standard callback URL.
# Otherwise Unified Chat uses {APP_BASE_URL}/auth/kick/callback automatically.
# KICK_REDIRECT_URI=https://your-public-domain/auth/kick/callback
KICK_SCOPE="events:subscribe moderation:ban moderation:chat_message:manage"
